{
  "ConnectionStrings": {
    "DefaultConnection": "Server=postgres;Port=5433;Database=cardduel;User Id=postgres;Password=postgres;"
  },
  "Jwt": {
    "Issuer": "cardduel-server",
    "Audience": "cardduel-clients",
    "SigningKey": "production-key-minimum-32-characters-long-xxxxxxxxxx"
  },
  "SignalR": {
    "RedisConnectionString": "redis:6379",
    "UseRedisBackplane": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "GameConfig": {
    "DisconnectGracePeriodSeconds": 20,
    "RankedDefaultRating": 1000,
    "DeckMinimumCards": 20,
    "DeckMaximumCards": 30,
    "MaxCardCopies": 3
  },
  "RateLimit": {
    "MaxRequestsPerWindow": 100,
    "WindowSizeSeconds": 60
  },
  "Reconnection": {
    "GracePeriodSeconds": 20
  },
  "TokenExpiry": {
    "ExpirySeconds": 3600
  }
}

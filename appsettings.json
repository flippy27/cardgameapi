{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=postgres;Port=5432;Database=cardduel;User Id=postgres;Password=postgres;"
  },
  "Jwt": {
    "Issuer": "cardduel-server",
    "Audience": "cardduel-clients",
    "SigningKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_FOR_PRODUCTION_AT_LEAST_32_CHARS"
  },
  "SignalR": {
    "UseRedisBackplane": false,
    "RedisConnectionString": "localhost:6379"
  },
  "Game": {
    "DisconnectGraceSeconds": 20,
    "RankedDefaultRating": 1000,
    "MaxDeckSize": 30,
    "MinDeckSize": 20
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
